VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# AI provider for Supabase Edge Functions.
# If OPENROUTER_API_KEY is set, AI functions use OpenRouter first.
# If it is empty, functions fall back to LOVABLE_API_KEY where available.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://127.0.0.1:8019
OPENROUTER_APP_TITLE=Multi Sale Organizer
LOVABLE_API_KEY=
